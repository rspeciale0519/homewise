# ============================================================
# Homewise FL — Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

# --- Database (Supabase Pooler — WSL2 compatible) -----------
# Transaction mode (port 6543) for application queries
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session mode (port 5432) for migrations and direct operations
DIRECT_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# --- Supabase Auth ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Agent Registration -------------------------------------
AGENT_INVITE_CODE=HWAGENT2026

# --- AI / LLM -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Email (Resend) -----------------------------------------
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
FROM_EMAIL=Homewise FL <noreply@homewisefl.com>

# --- SMS (Twilio) -------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Maps (Mapbox) ------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# --- Listing Enrichment -------------------------------------
WALK_SCORE_API_KEY=your-walk-score-api-key
GREATSCHOOLS_API_KEY=your-greatschools-api-key

# --- Background Jobs (Inngest) ------------------------------
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# --- Site URL (used for metadata, OG images, sitemaps) ------
NEXT_PUBLIC_SITE_URL=https://homewisefl.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Direct Mail (YellowLetterShop ordering) ----------------
# Inbox at YLS that receives new order emails
YLS_ORDERS_INBOX_EMAIL=sales@yellowlettershop.com
# Verified Resend sender for direct-mail order emails
HOMEWISE_DIRECT_MAIL_FROM_EMAIL=Homewise Direct Mail <direct-mail@email.homewisefl.com>
# Where dispatch-failure alerts get delivered
DIRECT_MAIL_ADMIN_ALERT_EMAIL=admin@homewisefl.com
# Minimum business days between order submission and target drop date
DIRECT_MAIL_DROP_DATE_MIN_BUSINESS_DAYS=5
# Private Supabase Storage bucket holding artwork, lists, and order summary PDFs
DIRECT_MAIL_STORAGE_BUCKET=direct-mail-orders
