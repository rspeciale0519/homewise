generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Agent {
  id               String        @id @default(cuid())
  firstName        String
  lastName         String
  slug             String        @unique
  email            String?
  phone            String?
  photoUrl         String?
  languages        String[]
  designations     String[]
  bio              String?
  active           Boolean       @default(true)
  inviteCode       String?       @unique
  inviteExpiresAt  DateTime?
  inviteUsed       Boolean       @default(false)
  mlsAgentId       String?
  mlsOfficeId      String?
  emailSignature   String?
  emailTagline     String?
  brandColor       String?
  userId           String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  preferredByUsers     UserProfile[]
  user                 UserProfile?        @relation("AgentUser", fields: [userId], references: [id])
  contacts             Contact[]
  stripeCustomer       StripeCustomer?
  subscription         Subscription?
  usageRecords         UsageRecord[]
  paymentRecords       PaymentRecord[]
  gracePeriodOverrides GracePeriodOverride[]
  documentDrafts       DocumentDraft[]
  documentFavorites    DocumentFavorite[]
  documentRecents      DocumentRecent[]

  @@index([lastName])
  @@index([active])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model HomeEvaluation {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  streetAddress  String
  city           String
  state          String   @default("FL")
  zip            String
  bedrooms       Int?
  bathrooms      Float?
  sqft           Int?
  garageSpaces   Int?
  propertyType   String?
  sellTimeline   String?
  listingStatus  String?
  comments       String?
  status         String   @default("new")
  createdAt      DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model BuyerRequest {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  areasOfInterest String?
  minPrice        Int?
  maxPrice        Int?
  beds            Int?
  baths           Int?
  propertyTypes   String[]
  timeline        String?
  comments        String?
  status          String   @default("new")
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model PropertyAlert {
  id        String       @id @default(cuid())
  email     String
  name      String?
  cities    String[]
  minPrice  Int?
  maxPrice  Int?
  beds      Int?
  active    Boolean      @default(true)
  userId    String?
  createdAt DateTime     @default(now())

  user      UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([email])
  @@index([userId])
}

model UserProfile {
  id             String   @id
  email          String   @unique
  firstName      String
  lastName       String
  phone          String?
  avatarUrl      String?
  role           String   @default("user")
  preferredAgent String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  favorites      FavoriteProperty[]
  savedSearches  SavedSearch[]
  recentlyViewed RecentlyViewed[]
  propertyAlerts PropertyAlert[]
  agent              Agent?   @relation(fields: [preferredAgent], references: [id])
  agentProfile       Agent?   @relation("AgentUser")
  documentSignature  DocumentSignature?

  @@index([email])
}

model FavoriteProperty {
  id         String      @id @default(cuid())
  userId     String
  propertyId String
  notes      String?
  savedAt    DateTime    @default(now())

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
}

model SavedSearch {
  id           String      @id @default(cuid())
  userId       String
  name         String
  filters      Json
  polygon      Json?
  matchingMode String      @default("balanced")
  rigidity     Int         @default(30)
  alertEnabled Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RecentlyViewed {
  id         String      @id @default(cuid())
  userId     String
  propertyId String
  viewedAt   DateTime    @default(now())

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([viewedAt])
}

model Listing {
  id                  String   @id @default(cuid())
  mlsId               String   @unique
  mlsSource           String   @default("stellar")
  status              String   @default("Active")
  price               Float
  closePrice          Float?
  originalListPrice   Float?
  address             String
  city                String
  state               String   @default("FL")
  zip                 String
  county              String?
  subdivision         String?
  beds                Int
  bathsFull           Int
  bathsHalf           Int
  baths               Float
  sqft                Int
  lotSize             Float?
  yearBuilt           Int?
  propertyType        String
  propertySubType     String?
  description         String?
  photos              String[]
  imageUrl            String?
  latitude            Float?
  longitude           Float?
  hoaFee              Float?
  hoaFrequency        String?
  taxAmount           Float?
  taxYear             Int?
  hasPool             Boolean  @default(false)
  hasWaterfront       Boolean  @default(false)
  hasGarage           Boolean  @default(false)
  garageSpaces        Int      @default(0)
  isNewConstruction   Boolean  @default(false)
  hasGatedCommunity   Boolean  @default(false)
  daysOnMarket        Int      @default(0)
  listDate            DateTime?
  closeDate           DateTime?
  openHouseSchedule   Json?
  schoolDistrict      String?
  elementarySchool    String?
  middleSchool        String?
  highSchool          String?
  listingAgentName    String?
  listingAgentMlsId   String?
  listingAgentPhone   String?
  listingAgentEmail   String?
  listingOfficeName   String?
  listingOfficeMlsId  String?
  walkScore           Int?
  transitScore        Int?
  bikeScore           Int?
  walkScoreUpdatedAt  DateTime?
  featured            Boolean  @default(false)
  virtualTourUrl      String?
  remarks             String?
  embedding           Float[]
  embeddingText       String?
  mlsLastModified     DateTime?
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([city])
  @@index([status])
  @@index([price])
  @@index([propertyType])
  @@index([mlsId])
  @@index([listingAgentMlsId])
  @@index([listingOfficeMlsId])
  @@index([featured])
  @@index([latitude, longitude])
  @@index([beds])
  @@index([daysOnMarket])
}

model WalkScoreCache {
  id           String   @id @default(cuid())
  addressKey   String   @unique
  walkScore    Int?
  transitScore Int?
  bikeScore    Int?
  description  String?
  rawResponse  Json?
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}

model SchoolCache {
  id        String   @id @default(cuid())
  latLngKey String   @unique
  schools   Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model SyncState {
  id           String   @id @default(cuid())
  provider     String   @unique @default("stellar")
  lastSyncAt   DateTime?
  totalSynced  Int      @default(0)
  lastError    String?
  status       String   @default("idle")
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =============================================================================
// CRM — Contact / Lead Management (B5)
// =============================================================================

model Contact {
  id              String            @id @default(cuid())
  firstName       String
  lastName        String
  email           String            @unique
  phone           String?
  source          String            @default("website")
  type            String            @default("buyer")
  stage           String            @default("new_lead")
  score           Int               @default(0)
  assignedAgentId String?
  notes           String?
  birthday        DateTime?
  closeAnniversary DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  assignedAgent   Agent?            @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  tags            ContactTag[]
  activities      ActivityEvent[]
  tasks           Task[]
  transactions    Transaction[]
  enrollments     CampaignEnrollment[]
  emailEvents     EmailEvent[]

  @@index([email])
  @@index([assignedAgentId])
  @@index([stage])
  @@index([source])
  @@index([type])
  @@index([score])
  @@index([createdAt])
}

// =============================================================================
// Tags & Segmentation (B8)
// =============================================================================

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#6366f1")
  createdAt DateTime     @default(now())

  contacts  ContactTag[]
}

model ContactTag {
  id        String   @id @default(cuid())
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// =============================================================================
// Activity Timeline (B6)
// =============================================================================

model ActivityEvent {
  id          String   @id @default(cuid())
  contactId   String
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([type])
  @@index([createdAt])
}

// =============================================================================
// Tasks & Reminders (B9)
// =============================================================================

model Task {
  id            String    @id @default(cuid())
  contactId     String?
  assignedTo    String?
  title         String
  description   String?
  dueDate       DateTime?
  completedAt   DateTime?
  priority      String    @default("medium")
  calendarEventId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contact       Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([completedAt])
}

// =============================================================================
// Transaction Tracker (B7)
// =============================================================================

model Transaction {
  id              String                @id @default(cuid())
  contactId       String
  address         String
  purchasePrice   Float
  closingDate     DateTime?
  status          String                @default("active")
  propertyId      String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  contact         Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  milestones      TransactionMilestone[]
  documents       TransactionDocument[]

  @@index([contactId])
  @@index([status])
  @@index([closingDate])
}

model TransactionMilestone {
  id            String       @id @default(cuid())
  transactionId String
  name          String
  targetDate    DateTime?
  completedAt   DateTime?
  notes         String?
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())

  transaction   Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model TransactionDocument {
  id            String       @id @default(cuid())
  transactionId String
  name          String
  type          String
  url           String?
  uploadedAt    DateTime?
  required      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  transaction   Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

// =============================================================================
// Lead Routing (B10 / I1)
// =============================================================================

model LeadRoutingRule {
  id            String   @id @default(cuid())
  name          String
  agentId       String
  conditions    Json
  priority      Int      @default(0)
  roundRobin    Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active])
  @@index([priority])
}

// =============================================================================
// Agent Training Hub (K1)
// =============================================================================

model TrainingContent {
  id           String              @id @default(cuid())
  title        String
  description  String?
  category     String
  audience     String              @default("agent")
  type         String              @default("video")
  url          String?
  body         String?
  fileKey      String?
  thumbnailUrl String?
  duration     Int?
  tags         String[]
  sortOrder    Int                 @default(0)
  published    Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  progress     TrainingProgress[]
  courseItems   TrainingCourseItem[]

  @@index([category])
  @@index([audience])
  @@index([published])
}

model TrainingCourse {
  id             String                @id @default(cuid())
  name           String
  description    String?
  thumbnailUrl   String?
  required       Boolean               @default(false)
  autoEnroll     Boolean               @default(false)
  reminderDays   Int?
  reminderRepeat Int?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  items          TrainingCourseItem[]
  enrollments    TrainingEnrollment[]

  @@map("TrainingTrack")
}

model TrainingCourseItem {
  id        String           @id @default(cuid())
  courseId  String           @map("trackId")
  contentId String
  sortOrder Int              @default(0)

  course    TrainingCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  content   TrainingContent  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([courseId, contentId], map: "TrainingTrackItem_trackId_contentId_key")
  @@index([courseId], map: "TrainingTrackItem_trackId_idx")
  @@map("TrainingTrackItem")
}

model TrainingEnrollment {
  id          String         @id @default(cuid())
  userId      String
  courseId    String         @map("trackId")
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  course      TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId], map: "TrainingEnrollment_userId_trackId_key")
  @@index([userId])
}

model TrainingProgress {
  id          String          @id @default(cuid())
  userId      String
  contentId   String
  completed   Boolean         @default(false)
  completedAt DateTime?
  timeSpent   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  content     TrainingContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
}

// =============================================================================
// Visitor Registration Wall (B1)
// =============================================================================

model RegistrationConfig {
  id             String  @id @default(cuid())
  viewThreshold  Int     @default(5)
  mode           String  @default("soft")
  enabled        Boolean @default(true)
  abTestVariant  String?
}

// =============================================================================
// Marketing Automation — Campaigns (C1)
// =============================================================================

model Campaign {
  id            String               @id @default(cuid())
  name          String
  type          String               @default("drip")
  status        String               @default("draft")
  triggerSource String?
  triggerType   String?
  triggerStage  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  emails        CampaignEmail[]
  enrollments   CampaignEnrollment[]

  @@index([status])
  @@index([type])
}

model CampaignEmail {
  id            String   @id @default(cuid())
  campaignId    String
  subject       String
  body          String
  delayDays     Int      @default(0)
  delayHours    Int      @default(0)
  sortOrder     Int      @default(0)
  channel       String   @default("email")
  smsBody       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variants      SubjectLineVariant[]

  @@index([campaignId])
}

model CampaignEnrollment {
  id            String    @id @default(cuid())
  campaignId    String
  contactId     String
  currentStep   Int       @default(0)
  status        String    @default("active")
  nextSendAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
  @@index([nextSendAt])
}

// =============================================================================
// Email Tracking (C8)
// =============================================================================

model EmailEvent {
  id            String   @id @default(cuid())
  contactId     String?
  emailAddress  String
  messageId     String?
  type          String
  subject       String?
  campaignId    String?
  variant       String?
  metadata      Json?
  createdAt     DateTime @default(now())

  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([emailAddress])
  @@index([messageId])
  @@index([type])
  @@index([campaignId])
  @@index([createdAt])
}

// =============================================================================
// AI Email Subject Line A/B Testing (G2)
// =============================================================================

model SubjectLineVariant {
  id              String        @id @default(cuid())
  campaignEmailId String
  variant         String
  subject         String
  sendCount       Int           @default(0)
  openCount       Int           @default(0)
  clickCount      Int           @default(0)
  createdAt       DateTime      @default(now())

  campaignEmail   CampaignEmail @relation(fields: [campaignEmailId], references: [id], onDelete: Cascade)

  @@unique([campaignEmailId, variant])
  @@index([campaignEmailId])
}

// =============================================================================
// Behavioral Trigger Automation (C5)
// =============================================================================

model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  triggerType String
  conditions  Json
  actionType  String
  actionData  Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([triggerType])
  @@index([active])
}

// =============================================================================
// Broadcast Emails (C7)
// =============================================================================

model Broadcast {
  id          String   @id @default(cuid())
  name        String
  subject     String
  body        String
  audienceTag String?
  audienceIds String[]
  status      String   @default("draft")
  sentAt      DateTime?
  sentCount   Int      @default(0)
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// =============================================================================
// Chatbot Engine (J)
// =============================================================================

model Conversation {
  id          String        @id @default(cuid())
  sessionId   String
  userId      String?
  agentId     String?
  config      String        @default("public")
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages    ChatMessage[]

  @@index([sessionId])
  @@index([userId])
  @@index([agentId])
  @@index([config])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  toolCalls      Json?
  toolResults    Json?
  tokenCount     Int          @default(0)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// =============================================================================
// AI Usage Tracking
// =============================================================================

model AiUsageLog {
  id          String   @id @default(cuid())
  feature     String
  userId      String?
  model       String
  inputTokens  Int     @default(0)
  outputTokens Int     @default(0)
  cached      Boolean  @default(false)
  latencyMs   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([feature])
  @@index([userId])
  @@index([createdAt])
}

// =============================================================================
// AI SEO Content (G4)
// =============================================================================

model SeoContent {
  id          String    @id @default(cuid())
  type        String
  slug        String    @unique
  title       String
  body        String
  metaTitle   String?
  metaDesc    String?
  city        String?
  neighborhood String?
  status      String    @default("draft")
  publishedAt DateTime?
  refreshedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([city])
}

// =============================================================================
// Market Statistics (D1)
// =============================================================================

model MarketStats {
  id              String   @id @default(cuid())
  area            String
  areaType        String   @default("city")
  period          String
  activeCount     Int      @default(0)
  soldCount       Int      @default(0)
  medianPrice     Float    @default(0)
  avgPrice        Float    @default(0)
  saleToListRatio Float    @default(0)
  avgDom          Int      @default(0)
  monthsOfInventory Float  @default(0)
  newListings     Int      @default(0)
  pricePerSqft    Float    @default(0)
  createdAt       DateTime @default(now())

  @@unique([area, areaType, period])
  @@index([area])
  @@index([period])
}

model AiFeatureConfig {
  id         String   @id @default(cuid())
  featureKey String   @unique
  label      String
  model      String
  tier       String
  updatedAt  DateTime @updatedAt

  @@index([featureKey])
}

// ─── Billing & Subscriptions ───────────────────────────────────

model StripeCustomer {
  id                   String   @id @default(cuid())
  agentId              String   @unique
  agent                Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  stripeCustomerId     String   @unique
  defaultPaymentMethod String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([stripeCustomerId])
}

model Subscription {
  id                   String             @id @default(cuid())
  agentId              String             @unique
  agent                Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  status               String             @default("active")
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  items                SubscriptionItem[]

  @@index([status])
  @@index([stripeSubscriptionId])
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeItemId   String       @unique
  productType    String
  productName    String
  stripePriceId  String
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
  @@index([productType])
}

model EntitlementConfig {
  id              String   @id @default(cuid())
  featureKey      String   @unique
  featureName     String
  requiredProduct String?
  freeLimit       Int?
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BundleConfig {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  stripeProductId String?
  monthlyPriceId  String?
  annualPriceId   String?
  monthlyAmount   Int
  annualAmount    Int
  productType     String
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  features        BundleFeature[]
}

model BundleFeature {
  id         String       @id @default(cuid())
  bundleId   String
  bundle     BundleConfig @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  featureKey String
  limit      Int?
  createdAt  DateTime     @default(now())

  @@unique([bundleId, featureKey])
  @@index([bundleId])
}

model UsageRecord {
  id                 String   @id @default(cuid())
  agentId            String
  agent              Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  featureKey         String
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  usageCount         Int      @default(0)
  updatedAt          DateTime @updatedAt

  @@unique([agentId, featureKey, billingPeriodStart])
  @@index([agentId])
}

model PaymentRecord {
  id                    String   @id @default(cuid())
  agentId               String
  agent                 Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?
  amount                Int
  currency              String   @default("usd")
  paymentType           String
  status                String   @default("succeeded")
  processedBy           String?
  notes                 String?
  createdAt             DateTime @default(now())

  @@index([agentId])
  @@index([status])
}

model GracePeriodOverride {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  extendedUntil DateTime
  reason        String
  grantedBy     String
  createdAt     DateTime @default(now())

  @@index([agentId])
}

model DocumentSignature {
  id        String   @id @default(cuid())
  userId    String   @unique
  imageData String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentDraft {
  id           String   @id @default(cuid())
  agentId      String
  documentPath String
  documentName String
  annotations  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, documentPath])
  @@index([agentId])
}

model DocumentFavorite {
  id           String   @id @default(cuid())
  agentId      String
  documentPath String
  documentName String
  savedAt      DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, documentPath])
  @@index([agentId])
}

model DocumentRecent {
  id           String   @id @default(cuid())
  agentId      String
  documentPath String
  documentName String
  viewedAt     DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, documentPath])
  @@index([agentId])
  @@index([viewedAt])
}

model BillingSettings {
  id                     String   @id @default(cuid())
  gracePeriodWarningDays Int      @default(7)
  gracePeriodUrgentDays  Int      @default(14)
  gracePeriodLockoutDays Int      @default(15)
  invoiceNotifyDays      Int      @default(7)
  trialDurationDays      Int      @default(14)
  transitionGraceDays    Int      @default(30)
  loyaltyDiscountPercent Int      @default(20)
  updatedAt              DateTime @updatedAt
}
