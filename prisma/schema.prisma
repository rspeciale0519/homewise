generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Agent {
  id               String        @id @default(cuid())
  firstName        String
  lastName         String
  slug             String        @unique
  email            String?
  phone            String?
  photoUrl         String?
  languages        String[]
  designations     String[]
  bio              String?
  active           Boolean       @default(true)
  inviteCode       String?       @unique
  inviteExpiresAt  DateTime?
  inviteUsed       Boolean       @default(false)
  mlsAgentId       String?
  mlsOfficeId      String?
  userId           String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  preferredByUsers UserProfile[]
  user             UserProfile?  @relation("AgentUser", fields: [userId], references: [id])

  @@index([lastName])
  @@index([active])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model HomeEvaluation {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  streetAddress  String
  city           String
  state          String   @default("FL")
  zip            String
  bedrooms       Int?
  bathrooms      Float?
  sqft           Int?
  garageSpaces   Int?
  propertyType   String?
  sellTimeline   String?
  listingStatus  String?
  comments       String?
  status         String   @default("new")
  createdAt      DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model BuyerRequest {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  areasOfInterest String?
  minPrice        Int?
  maxPrice        Int?
  beds            Int?
  baths           Int?
  propertyTypes   String[]
  timeline        String?
  comments        String?
  status          String   @default("new")
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model PropertyAlert {
  id        String       @id @default(cuid())
  email     String
  name      String?
  cities    String[]
  minPrice  Int?
  maxPrice  Int?
  beds      Int?
  active    Boolean      @default(true)
  userId    String?
  createdAt DateTime     @default(now())

  user      UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([email])
  @@index([userId])
}

model UserProfile {
  id             String   @id
  email          String   @unique
  firstName      String
  lastName       String
  phone          String?
  avatarUrl      String?
  role           String   @default("user")
  preferredAgent String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  favorites      FavoriteProperty[]
  savedSearches  SavedSearch[]
  recentlyViewed RecentlyViewed[]
  propertyAlerts PropertyAlert[]
  agent          Agent?   @relation(fields: [preferredAgent], references: [id])
  agentProfile   Agent?   @relation("AgentUser")

  @@index([email])
}

model FavoriteProperty {
  id         String      @id @default(cuid())
  userId     String
  propertyId String
  notes      String?
  savedAt    DateTime    @default(now())

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
}

model SavedSearch {
  id           String      @id @default(cuid())
  userId       String
  name         String
  filters      Json
  polygon      Json?
  matchingMode String      @default("balanced")
  rigidity     Int         @default(30)
  alertEnabled Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RecentlyViewed {
  id         String      @id @default(cuid())
  userId     String
  propertyId String
  viewedAt   DateTime    @default(now())

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([viewedAt])
}

model Listing {
  id                  String   @id @default(cuid())
  mlsId               String   @unique
  mlsSource           String   @default("stellar")
  status              String   @default("Active")
  price               Float
  closePrice          Float?
  originalListPrice   Float?
  address             String
  city                String
  state               String   @default("FL")
  zip                 String
  county              String?
  subdivision         String?
  beds                Int
  bathsFull           Int
  bathsHalf           Int
  baths               Float
  sqft                Int
  lotSize             Float?
  yearBuilt           Int?
  propertyType        String
  propertySubType     String?
  description         String?
  photos              String[]
  imageUrl            String?
  latitude            Float?
  longitude           Float?
  hoaFee              Float?
  hoaFrequency        String?
  taxAmount           Float?
  taxYear             Int?
  hasPool             Boolean  @default(false)
  hasWaterfront       Boolean  @default(false)
  hasGarage           Boolean  @default(false)
  garageSpaces        Int      @default(0)
  isNewConstruction   Boolean  @default(false)
  hasGatedCommunity   Boolean  @default(false)
  daysOnMarket        Int      @default(0)
  listDate            DateTime?
  closeDate           DateTime?
  openHouseSchedule   Json?
  schoolDistrict      String?
  elementarySchool    String?
  middleSchool        String?
  highSchool          String?
  listingAgentName    String?
  listingAgentMlsId   String?
  listingAgentPhone   String?
  listingAgentEmail   String?
  listingOfficeName   String?
  listingOfficeMlsId  String?
  walkScore           Int?
  transitScore        Int?
  bikeScore           Int?
  walkScoreUpdatedAt  DateTime?
  featured            Boolean  @default(false)
  virtualTourUrl      String?
  remarks             String?
  mlsLastModified     DateTime?
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([city])
  @@index([status])
  @@index([price])
  @@index([propertyType])
  @@index([mlsId])
  @@index([listingAgentMlsId])
  @@index([listingOfficeMlsId])
  @@index([featured])
  @@index([latitude, longitude])
  @@index([beds])
  @@index([daysOnMarket])
}

model WalkScoreCache {
  id           String   @id @default(cuid())
  addressKey   String   @unique
  walkScore    Int?
  transitScore Int?
  bikeScore    Int?
  description  String?
  rawResponse  Json?
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}

model SchoolCache {
  id        String   @id @default(cuid())
  latLngKey String   @unique
  schools   Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model SyncState {
  id           String   @id @default(cuid())
  provider     String   @unique @default("stellar")
  lastSyncAt   DateTime?
  totalSynced  Int      @default(0)
  lastError    String?
  status       String   @default("idle")
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
